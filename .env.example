LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

DEEPSEEK_API_KEY=your_deepseek_api_key

LIFF_ID=your_liff_id
LIFF_QUOTE_ID=your_liff_quote_id
LIFF_PRODUCT_SEARCH_ID=your_liff_product_search_id

# รันแบบ Docker: PG_HOST ต้องเป็น "db" (ชื่อ service) — docker-compose override ให้อยู่แล้ว
# รันแบบ local (ไม่ใช้ Docker): ใช้ localhost
PG_HOST=db
PG_PORT=5432
PG_DATABASE=chatbot_primus
PG_USER=postgres
PG_PASSWORD=your_db_password

Product_full_sync=your_product_sync_key
Customer_full_sync=your_customer_sync_key
Saleorder_full_sync=your_saleorder_sync_key

gateway_host=http://localhost:5173/

JWT_SECRET=your_jwt_secret
NODE_ENV=development

# พอร์ตบน host ที่ผูกกับ 127.0.0.1 ให้ reverse proxy กลางของ IT วิ่งเข้ามา (Docker เท่านั้น)
# ถาม IT ว่าพอร์ตไหนว่าง แล้วแจ้งพอร์ตนี้ให้ IT ผูกกับ subdomain
APP_PORT=3011
